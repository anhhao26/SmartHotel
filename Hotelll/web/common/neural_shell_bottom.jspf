    </div>
    <!-- Boutique Background Decor -->
    <div class="absolute inset-0 z-[-1] overflow-hidden opacity-30 pointer-events-none bg-hotel-cream">
        <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-hotel-gold/5 blur-[100px] rounded-full translate-x-1/3 -translate-y-1/3"></div>
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-hotel-gold/5 blur-[80px] rounded-full -translate-x-1/2 translate-y-1/2"></div>
    </div>
</main>
